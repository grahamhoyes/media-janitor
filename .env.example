DEBUG=1
# Set a secret key. The application will not start without one.
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://media_janitor:media_janitor@localhost:5432/media_janitor

# Path where Media Janitor sees the media share root. The scan walks everything under it.
SHARE_ROOT=/data

QBIT_HOST=http://localhost:8080
# qBittorrent 5.2 WebUI API key (Settings > WebUI > Authentication > API Key)
QBIT_API_KEY=
# Data mount point that, when stripped, gives a share-relative path. Example:
#   Absolute path on the NAS: /volume1/media/torrents/{movies,tv}
#   Share (NFS paths are relative to this): /volume1/media
#   Share-relative torrents path: /torrents/{movies,tv}
#   qBittorrent mount path: /data/torrents/{movies,tv}
#   qBittorrent data root: /data
QBIT_DATA_ROOT=/data

## == These are only used with docker-compose.yml ==
# NFS share for the web/worker services
NFS_SERVER=your-nas.example.com
NFS_EXPORT_PATH=/volume1/media
# User and group ID to run the worker container as. Change these if your NFS server
# expects different users.
NFS_UID=1000
NFS_GID=1000
