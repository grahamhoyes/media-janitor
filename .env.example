DEBUG=1
SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://media_janitor:media_janitor@localhost:5432/media_janitor

QBIT_HOST=http://localhost:8080
# qBittorrent 5.2 WebUI API key (Settings > WebUI > Authentication > API Key)
QBIT_API_KEY=
# Data mount point that, when stripped, gives a share-relative path. Example:
#   Absolute path on the NAS: /volume1/media/torrents/{movies,tv}
#   Share (NFS paths are relative to this): /volume1/media
#   Share-relative torrents path: /torrents/{movies,tv}
#   qBittorrent mount path: /data/torrents/{movies,tv}
#   qBittorrent data root: /data
QBIT_DATA_ROOT=/data
